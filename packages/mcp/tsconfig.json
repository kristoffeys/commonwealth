{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // No rootDir: typecheck (tsc --noEmit) pulls @commonwealth/core source in via `paths`
    // below, which would violate a src-only rootDir. tsup owns the actual build/emit.
    "paths": {
      // Resolve the workspace dep to source so typecheck needs no prior build of core.
      // tsup still externalizes @commonwealth/core at build time (it's a dependency).
      "@commonwealth/core": ["../core/src/index.ts"]
    }
  },
  "include": ["src"]
}
