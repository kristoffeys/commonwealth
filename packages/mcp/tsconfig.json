{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // No rootDir: typecheck (tsc --noEmit) pulls @cmnwlth/core source in via `paths`
    // below, which would violate a src-only rootDir. tsup owns the actual build/emit.
    "paths": {
      // Resolve workspace deps to source so typecheck needs no prior build of core/curate.
      // tsup still externalizes them at build time (they're dependencies).
      "@cmnwlth/core": ["../core/src/index.ts"],
      // curate's LIBRARY entry (src/lib.ts) — NOT src/index.ts, which is the CLI (#82).
      "@cmnwlth/curate": ["../curate/src/lib.ts"]
    }
  },
  "include": ["src"]
}
